# Basic .gitattributes for a python repo.

# Source files
# ============
*.pxd    text diff=python
*.py     text diff=python
*.py3    text diff=python
*.pyw    text diff=python
*.pyx    text diff=python
*.pyz    text diff=python
*.pyi    text diff=python

# Project files
# =============
*.md     text eol=lf
*.toml   text eol=lf
*.txt    text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf

# Binary files
# ============
*.db     binary
*.gif    binary
*.jpeg   binary
*.jpg    binary
*.onnx   binary
*.p      binary
*.pkl    binary
*.pickle binary
*.png    binary
*.pt     binary
*.pth    binary
*.pyc    binary export-ignore
*.pyo    binary export-ignore
*.pyd    binary
*.webp   binary
*.zip    binary

# Jupyter notebook
*.ipynb  text eol=lf

# Note: .db, .p, and .pkl files are associated
# with the python modules ``pickle``, ``dbm.*``,
# ``shelve``, ``marshal``, ``anydbm``, & ``bsddb``
# (among others).
